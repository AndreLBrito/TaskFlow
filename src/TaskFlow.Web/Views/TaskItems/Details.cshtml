@model TaskFlow.Web.ViewModels.TaskItems.Details.TaskItemDetailsViewModel

<h1>@Model.Title</h1>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <p>
        @Model.Description
    </p>
}

@if (Model.DueDate.HasValue)
{
    <p>
        <strong>Prazo:</strong>
        @Model.DueDate.Value.ToString("dd/MM/yyyy")
    </p>
}
<a asp-controller="Boards" asp-action="Details" asp-route-id="@Model.BoardId" class="btn btn-secondary">
    Voltar para quadro
</a>
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
    Editar
</a>
<a asp-action="Move" asp-route-id="@Model.Id" class="btn btn-info">
    Mover
</a>
<form asp-action="Delete" method="post" class="d-inline">

    @Html.AntiForgeryToken()

    <input type="hidden" name="id" value="@Model.Id" />

    <input type="hidden" name="boardId" value="@Model.BoardId" />

    <button type="submit" class="btn btn-danger" onclick="return confirm('Deseja realmente excluir esta tarefa?');">
        Excluir
    </button>
</form>