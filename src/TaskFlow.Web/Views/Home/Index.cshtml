@model TaskFlow.Web.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">
    Dashboard
</h1>

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h2>@Model.WorkspacesCount</h2>
                <p>Workspaces</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h2>@Model.BoardsCount</h2>
                <p>Quadros</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h2>@Model.TasksCount</h2>
                <p>Tarefas</p>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h2>@Model.CompletedTasksCount</h2>
                <p>Concluídas</p>
            </div>
        </div>
    </div>

</div>

<div class="mt-4">
    <a asp-controller="Workspaces"
       asp-action="Index"
       class="btn btn-primary">
        Gerenciar Workspaces
    </a>
</div>