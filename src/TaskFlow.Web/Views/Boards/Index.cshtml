@model TaskFlow.Web.ViewModels.Boards.List.BoardListViewModel
<a asp-controller="Workspaces" asp-action="Details" asp-route-id="@Model.WorkspaceId" class="btn btn-secondary mb-3">
    Voltar para workspace
</a>
@{
    ViewData["Title"] = "Quadros";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Quadros</h1>

    <a asp-action="Create" asp-route-workspaceId="@Model.WorkspaceId" class="btn btn-primary">
        Novo quadro
    </a>
</div>

@if (!Model.Boards.Any())
{
    <div class="alert alert-info">
        Nenhum quadro cadastrado.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Data de criação</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var board in Model.Boards)
            {
                <tr>
                    <td>@board.Name</td>
                    <td>@board.Description</td>
                    <td>@board.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@board.Id" class="btn btn-sm btn-outline-primary">
                            Detalhes
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}