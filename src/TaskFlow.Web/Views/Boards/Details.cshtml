@model TaskFlow.Web.ViewModels.Boards.Details.BoardDetailsViewModel
<a asp-controller="Workspaces" asp-action="Details" asp-route-id="@Model.WorkspaceId" class="btn btn-secondary mb-3">
    Voltar para workspace
</a>
@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>

<p>
    @Model.Description
</p>

<h3 class="mt-4">Colunas</h3>

<div class="row">
    @foreach (var column in Model.Columns)
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    @column.Name
                </div>

                <div class="card-body">

                    <a asp-controller="TaskItems" asp-action="Create" asp-route-boardId="@Model.Id"
                       asp-route-boardColumnId="@column.Id" class="btn btn-sm btn-primary mb-2">
                        Nova tarefa
                    </a>

                    @if (!column.Tasks.Any())
                    {
                        <p class="text-muted">
                            Nenhuma tarefa.
                        </p>
                    }
                    else
                    {
                        @foreach (var task in column.Tasks)
                        {
                            <div class="card mb-2">
                                <div class="card-body">

                                    <strong>
                                        @task.Title
                                    </strong>

                                    @if (!string.IsNullOrWhiteSpace(task.Description))
                                    {
                                        <p class="mb-0">
                                            @task.Description
                                        </p>
                                    }

                                </div>
                            </div>
                        }
                    }

                </div>
            </div>
        </div>
    }
</div>

<p>
    <strong>Criado em:</strong>
    @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
</p>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
    Editar
</a>

<form asp-action="Delete" method="post" class="d-inline">

    @Html.AntiForgeryToken()

    <input type="hidden" name="id" value="@Model.Id" />

    <input type="hidden" name="workspaceId" value="@Model.WorkspaceId" />

    <button type="submit" class="btn btn-danger" onclick="return confirm('Deseja realmente excluir este quadro?');">
        Excluir
    </button>
</form>