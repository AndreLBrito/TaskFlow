<form id="anti-forgery-form">
    @Html.AntiForgeryToken()
</form>

@model TaskFlow.Web.ViewModels.Boards.Details.BoardDetailsViewModel
<a asp-controller="Workspaces" asp-action="Details" asp-route-id="@Model.WorkspaceId" class="btn btn-secondary mb-3">
    Voltar para workspace
</a>
@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>

<p>
    @Model.Description
</p>

<h3 class="mt-4">Colunas</h3>

<div class="row">
    @foreach (var column in Model.Columns)
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    @column.Name
                </div>

                <div class="card-body">

                    <a asp-controller="TaskItems" asp-action="Create" asp-route-boardId="@Model.Id"
                       asp-route-boardColumnId="@column.Id" class="btn btn-sm btn-primary mb-2">
                        Nova tarefa
                    </a>

                    <div class="kanban-column" data-column-id="@column.Id">

                        @if (!column.Tasks.Any())
                        {
                            <p class="text-muted empty-column-message">
                                Nenhuma tarefa.
                            </p>
                        }

                        @foreach (var task in column.Tasks)
                        {
                            <div class="card mb-2 kanban-task" data-task-id="@task.Id">

                                <div class="card-body">

                                    <a asp-controller="TaskItems" asp-action="Details" asp-route-id="@task.Id">
                                        @task.Title
                                    </a>

                                    @if (!string.IsNullOrWhiteSpace(task.Description))
                                    {
                                        <p class="mb-0">
                                            @task.Description
                                        </p>
                                    }

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<p>
    <strong>Criado em:</strong>
    @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
</p>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
    Editar
</a>

<form asp-action="Delete" method="post" class="d-inline">

    @Html.AntiForgeryToken()

    <input type="hidden" name="id" value="@Model.Id" />

    <input type="hidden" name="workspaceId" value="@Model.WorkspaceId" />

    <button type="submit" class="btn btn-danger" onclick="return confirm('Deseja realmente excluir este quadro?');">
        Excluir
    </button>
</form>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.7/Sortable.min.js"></script>

    <script>
        document.querySelectorAll('.kanban-column').forEach(column => {
        new Sortable(column, {
        group: 'kanban',
        animation: 150,
        draggable: '.kanban-task',

        onEnd: async function (event) {
        const taskId = event.item.dataset.taskId;
        const targetColumnId = event.to.dataset.columnId;
        const newOrder = event.newIndex;

        const token = document.querySelector(
        'input[name="__RequestVerificationToken"]'
        ).value;

        const formData = new FormData();
        formData.append('id', taskId);
        formData.append('boardColumnId', targetColumnId);
        formData.append('order', newOrder);
        formData.append('__RequestVerificationToken', token);

        const response = await fetch('/TaskItems/MoveAjax', {
        method: 'POST',
        body: formData
        });

        if (!response.ok) {
        alert('Não foi possível mover a tarefa.');
        window.location.reload();
        return;
        }

        document.querySelectorAll('.kanban-column').forEach(column => {
        const emptyMessage = column.querySelector('.empty-column-message');
        const hasTasks = column.querySelectorAll('.kanban-task').length > 0;

        if (emptyMessage) {
        emptyMessage.style.display = hasTasks ? 'none' : 'block';
        }
        });
        }
        });
        });
    </script>
}